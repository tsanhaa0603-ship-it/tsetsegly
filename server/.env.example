# MongoDB Atlas холболтын URI (cloud.mongodb.com → Connect → Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tsetsegly?retryWrites=true&w=majority

# JWT нууц түлхүүр (урт, санамсаргүй мөр)
JWT_SECRET=replace-with-a-long-random-secret

# Сервер порт
PORT=5000

# Admin нэвтрэх мэдээлэл
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ── QPay V2 төлбөрийн систем (merchant.qpay.mn) ──
QPAY_USERNAME=your-qpay-username
QPAY_PASSWORD=your-qpay-password
QPAY_INVOICE_CODE=your-invoice-code
QPAY_BASE_URL=https://merchant.qpay.mn/v2
# Callback хүлээн авах backend-ийн public домэйн
QPAY_CALLBACK_BASE=https://your-api-domain.vercel.app
